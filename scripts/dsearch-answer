#!/usr/bin/env python3
# dsearch2-answer — Passage-first answer pipeline using dsearch2 retriever.
# Retrieves ranked passages via dsearch2 --json, builds context, calls Claude for synthesis.
# Keywords: dsearch2-answer, passage pipeline, RAG, answer, semantic search, Claude
import sys, os, json, subprocess, argparse, textwrap

# ── Constants ───────────────────────────────────────────────────────────────
DEFAULT_TOP_PASSAGES = 50   # how many passages to retrieve from dsearch2
DEFAULT_TOP_ANSWER   = 20   # how many passages to feed to Claude for answer synthesis
DEFAULT_MAX_PER_FILE = 4    # diversity cap: max chunks from one file in answer context
DSEARCH2_BIN = '/usr/local/bin/dsearch2'

# ── Helpers ─────────────────────────────────────────────────────────────────

def run_dsearch2(query, top_n, no_alias=False, cohere=False, hyde=False):
    cmd = [DSEARCH2_BIN, '--json', '--top', str(top_n)]
    if no_alias:
        cmd.append('--no-alias')
    if cohere:
        cmd.append('--cohere')
    if hyde:
        cmd.append('--hyde')
    cmd.append(query)
    try:
        cp = subprocess.run(cmd, capture_output=True, text=True, timeout=90)
        if cp.returncode != 0:
            print(f'ERROR: dsearch2 failed: {cp.stderr.strip()}', file=sys.stderr)
            return None
        return json.loads(cp.stdout)
    except subprocess.TimeoutExpired:
        print('ERROR: dsearch2 timed out', file=sys.stderr)
        return None
    except json.JSONDecodeError as e:
        print(f'ERROR: dsearch2 JSON parse error: {e}', file=sys.stderr)
        return None

def run_claude(prompt, timeout=120):
    # spawn claude -p - subprocess, feed prompt via stdin
    cmd = ['claude', '-p', '-']
    model = os.environ.get('DSEARCH2_MODEL')
    if model:
        cmd = ['claude', '--model', model, '-p', '-']
    try:
        cp = subprocess.run(cmd, capture_output=True, timeout=timeout, input=prompt, text=True)
        return cp.stdout.strip()
    except subprocess.TimeoutExpired:
        return '[timeout]'
    except Exception as e:
        return f'[error: {e}]'

def apply_diversity_filter(passages, max_per_file=DEFAULT_MAX_PER_FILE):
    from collections import Counter
    file_counts = Counter()
    filtered = []
    for p in passages:
        path = p.get('path', '')
        if file_counts[path] < max_per_file:
            file_counts[path] += 1
            filtered.append(p)
    return filtered

def file_distribution(passages):
    from collections import Counter
    return dict(Counter(os.path.basename(p.get('path', '?')) for p in passages).most_common())

def build_context(passages, max_passages=DEFAULT_TOP_ANSWER):
    # build passage context block for the LLM prompt
    lines = []
    for p in passages[:max_passages]:
        tier = p.get('source_tier', '?')
        path = p.get('path', '?')
        cid = p.get('chunk_id', '?')
        score = p.get('score', 0)
        text = p.get('text', '').strip()
        lines.append(f'[P{p["rank"]}] tier={tier} score={score:.4f} path={path} chunk={cid}')
        lines.append(text)
        lines.append('')
    return '\n'.join(lines)

def build_answer_prompt(query, query_expanded, passages_context):
    # the synthesis prompt sent to Claude
    return textwrap.dedent(f"""\
        You are a document analyst answering a query from a personal archive.
        The user searched their disk for: "{query}"
        (expanded query: "{query_expanded}")

        Below are the top ranked passages retrieved from the archive. Each passage
        has a source tier (A=official/authority, B=professional, C=personal notes, D=ambiguous),
        a file path, a chunk ID, and a relevance score.

        PASSAGES:
        {passages_context}

        INSTRUCTIONS:
        1. Answer the query using ONLY information from the passages above.
        2. For each claim, cite the source: [P<rank>] path, tier.
        3. Mark each claim's evidence status:
           - CONFIRMED: supported by tier A source
           - SUPPORTED: supported by tier B source
           - UNCONFIRMED: only tier C/D sources
           - WEAK: single source, no corroboration
        4. If passages don't contain enough to answer, say so explicitly.
        5. Output format:
           ANSWER:
           <your answer with inline citations>

           CLAIM EVIDENCE:
           - Claim: <claim text>
             Status: <CONFIRMED|SUPPORTED|UNCONFIRMED|WEAK>
             Sources: [P<n>] <path> (tier <X>)
             Key quote: "<relevant excerpt>"

           SOURCES:
           <numbered list of unique source files with tier>
    """)

# ── Output formatters ───────────────────────────────────────────────────────

TIER_COLOR = {'A': '\033[32m', 'B': '\033[34m', 'C': '\033[33m', 'D': '\033[90m'}
RESET = '\033[0m'

def print_passages(passages, max_show=10):
    # show retrieved passages in terminal
    print(f'\n{"="*60}')
    print(f'RETRIEVED PASSAGES (top {min(max_show, len(passages))} of {len(passages)})')
    print(f'{"="*60}\n')
    for p in passages[:max_show]:
        tier = p.get('source_tier', '?')
        color = TIER_COLOR.get(tier, '')
        path = p.get('path', '?')
        text = p.get('text', '').replace('\n', ' ')[:150]
        print(f'  {p["rank"]:3d}. [{color}{tier}{RESET}] {p["score"]:.4f}  {path}')
        print(f'       {text}')
        print()

def build_json_output(query_orig, query_expanded, aliases_used, answer_text, passages):
    return json.dumps({
        'query_original': query_orig,
        'query_expanded': query_expanded,
        'aliases_used': aliases_used,
        'answer': answer_text,
        'passages_used': len(passages),
        'passages': passages
    }, ensure_ascii=False, indent=2)

# ── Main ────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog='dsearch2-answer',
        description='Passage-first answer pipeline (dsearch2 retriever + Claude synthesis)')
    parser.add_argument('query', nargs='*', help='search query words')
    parser.add_argument('--json', action='store_true', help='JSON output')
    parser.add_argument('--top', '-n', type=int, default=DEFAULT_TOP_PASSAGES,
                        help=f'passages to retrieve (default {DEFAULT_TOP_PASSAGES})')
    parser.add_argument('--show-passages', action='store_true', help='show retrieved passages before answer')
    parser.add_argument('--no-alias', action='store_true', help='disable alias expansion')
    parser.add_argument('--cohere', action='store_true', help='use Cohere vector arm (faster, requires API key)')
    parser.add_argument('--hyde', action='store_true', help='enable HyDE (hypothetical document embedding via Ollama)')
    parser.add_argument('--model', type=str, default=None, help='Claude model override (e.g. claude-haiku-4-5-20251001)')
    parser.add_argument('--dry-run', action='store_true', help='retrieve passages and build prompt but do not call Claude')
    parser.add_argument('--max-per-file', type=int, default=DEFAULT_MAX_PER_FILE,
                        help=f'max chunks per file in answer context (default {DEFAULT_MAX_PER_FILE})')
    parser.add_argument('--no-diversity', action='store_true', help='disable per-file diversity cap')
    args = parser.parse_args()

    if not args.query:
        parser.print_help()
        sys.exit(0)

    query_orig = ' '.join(args.query)

    if args.model:
        os.environ['DSEARCH2_MODEL'] = args.model

    # retrieve passages via dsearch2
    print(f'Retrieving passages for: "{query_orig}" ...', file=sys.stderr)
    data = run_dsearch2(query_orig, args.top, no_alias=args.no_alias, cohere=args.cohere, hyde=args.hyde)
    if data is None:
        sys.exit(1)

    query_expanded = data.get('query_expanded', query_orig)
    aliases_used = data.get('aliases_used', [])
    passages = data.get('results', [])
    message = data.get('message', '')

    # empty collection handling
    if not passages:
        empty_msg = message or 'No passages found. Collection may be empty — run dsearch2-update first.'
        if args.json:
            print(build_json_output(query_orig, query_expanded, aliases_used, empty_msg, []))
        else:
            print(f'\n{empty_msg}')
            if aliases_used:
                print(f'Aliases expanded: {", ".join(aliases_used[:10])}')
        sys.exit(0)

    # show raw passages if requested
    if args.show_passages and not args.json:
        print_passages(passages)

    # diversity filter
    raw_count = len(passages)
    raw_dist = file_distribution(passages[:DEFAULT_TOP_ANSWER])
    if args.no_diversity:
        answer_passages = passages
    else:
        answer_passages = apply_diversity_filter(passages, max_per_file=args.max_per_file)
    filtered_count = len(answer_passages)
    filtered_dist = file_distribution(answer_passages[:DEFAULT_TOP_ANSWER])

    # renumber ranks for answer context (keep original rank in metadata)
    for i, p in enumerate(answer_passages):
        p['answer_rank'] = i + 1

    # build context and prompt
    context = build_context(answer_passages, max_passages=DEFAULT_TOP_ANSWER)
    prompt = build_answer_prompt(query_orig, query_expanded, context)

    if args.dry_run:
        diversity_mode = 'OFF (--no-diversity)' if args.no_diversity else f'ON (max {args.max_per_file}/file)'
        print(f'\n[DRY RUN] Diversity: {diversity_mode}')
        print(f'Raw passages retrieved: {raw_count}')
        print(f'After diversity filter: {filtered_count}')
        print(f'Passages to Claude: {min(filtered_count, DEFAULT_TOP_ANSWER)}')
        print(f'Prompt size: {len(prompt)} chars')
        print(f'Query expanded: {query_expanded}')
        if aliases_used:
            print(f'Aliases: {", ".join(aliases_used[:10])}')
        print(f'\nFile distribution BEFORE diversity (top {DEFAULT_TOP_ANSWER}):')
        for fname, cnt in raw_dist.items():
            print(f'  {fname}: {cnt}')
        print(f'\nFile distribution AFTER diversity (top {DEFAULT_TOP_ANSWER}):')
        for fname, cnt in filtered_dist.items():
            print(f'  {fname}: {cnt}')
        sys.exit(0)

    # call Claude for synthesis
    print(f'Synthesizing answer from {min(filtered_count, DEFAULT_TOP_ANSWER)} passages ...', file=sys.stderr)
    answer = run_claude(prompt, timeout=120)

    if answer.startswith('[timeout]') or answer.startswith('[error'):
        print(f'ERROR: Claude failed: {answer}', file=sys.stderr)
        sys.exit(1)

    used = answer_passages[:DEFAULT_TOP_ANSWER]
    # output
    if args.json:
        print(build_json_output(query_orig, query_expanded, aliases_used, answer, used))
    else:
        if aliases_used:
            print(f'Aliases expanded: {", ".join(aliases_used[:10])}')
        diversity_note = '' if args.no_diversity else f', max {args.max_per_file}/file'
        print(f'\n{"="*60}')
        print('ANSWER')
        print(f'{"="*60}\n')
        print(answer)
        print(f'\n{"="*60}')
        print(f'Based on {len(used)} passages from {len(set(p["path"] for p in used))} files{diversity_note}')

if __name__ == '__main__':
    main()
