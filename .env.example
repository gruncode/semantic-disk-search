# Copy this to ~/.config/dsearch/.env and fill in your values.
# dsearch sources this file at startup.

# ── API Keys ─────────────────────────────────────────────────────
COHERE_API_KEY=your-cohere-api-key-here

# ── Paths ────────────────────────────────────────────────────────
# Root of your document corpus (the directory you want to search)
CORPUS_DIR=~/Documents

# Where FAISS indexes are stored (one subdir per model)
FAISS_BASE=~/.local/share/dsearch/faiss

# ChromaDB persistent store
CHROMADB_DIR=~/.local/share/dsearch/chromadb

# Recoll Xapian BM25 database (built by recollindex)
XAPIAN_DB=~/.local/share/dsearch/xapiandb

# ── Python venvs ─────────────────────────────────────────────────
# Venv with: cohere, chromadb, faiss-cpu, transformers<=4.49 (for GTE)
VENV_GTE=~/venvs/gte-embed/bin/python3

# Venv with: transformers>=5.0, faiss-cpu, jupyter
VENV_TF=~/venvs/transformers/bin/python3

# HuggingFace model cache (can be shared between venvs)
HF_HOME=~/.cache/huggingface

# ── Cloud (optional — only needed for GPU-accelerated index builds) ──
GCP_PROJECT=YOUR_GCP_PROJECT
GCP_INSTANCE=embedding-gpu
GCP_ZONE=europe-west1-b
